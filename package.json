{
  "name": "fix-lang",
  "version": "0.1.0",
  "description": "A local macOS app that uses OpenAI to fix grammar and improve writing style",
  "author": {
    "name": "Anhdd Kuro",
    "email": "anhdd.kuro@gmail.com"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "start": "electron-vite preview",
    "predev": "bun run build",
    "dev": "electron-vite dev",
    "pack": "rm -rf release && electron-vite build && electron-builder --mac",
    "build": "electron-vite build",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint ./src",
    "vitest": "vitest",
    "test": "vitest --watch=false",
    "test:w": "vitest"
  },
  "devDependencies": {
    "@openrouter/ai-sdk-provider": "^0.4.5",
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitest/coverage-v8": "^3.1.2",
    "ai": "^4.3.11",
    "autoprefixer": "^10.4.21",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "9.25.1",
    "eslint-config-prettier": "10.1.2",
    "eslint-import-resolver-typescript": "4.3.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-import-x": "4.11.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.2.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-tailwindcss": "3.18.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "eslint-plugin-vitest": "0.5.4",
    "prettier": "3.5.3",
    "react-select": "^5.10.1",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vite": "6.3.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "3.1.2"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "applescript": "^1.0.0",
    "clipboardy": "^4.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^10.0.1",
    "languagedetect": "^2.0.0",
    "node-mac-permissions": "^2.5.0",
    "openai": "^4.96.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "build": {
    "appId": "com.fixlang.app",
    "productName": "FixLang",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}