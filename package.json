{
  "name": "fix-lang",
  "version": "0.1.0",
  "description": "A local macOS app that uses OpenAI to fix grammar and improve writing style",
  "author": {
    "name": "Anhdd Kuro",
    "email": "anhdd.kuro@gmail.com"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "start": "electron-vite preview",
    "predev": "bun run build",
    "dev": "electron-vite dev",
    "pack": "rm -rf release && electron-vite build && electron-builder",
    "build": "rm -rf release && electron-vite build"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "clipboardy": "^4.0.0",
    "dotenv": "^16.5.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^10.0.1",
    "languagedetect": "^2.0.0",
    "node-mac-permissions": "^2.5.0",
    "openai": "^4.93.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite-plugin-electron": "^0.29.0"
  },
  "build": {
    "appId": "com.fixlang.app",
    "productName": "FixLang",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}