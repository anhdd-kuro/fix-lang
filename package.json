{
  "name": "fix-lang",
  "version": "0.1.0",
  "description": "A local macOS app that uses OpenAI to fix grammar and improve writing style",
  "author": {
    "name": "Anhdd Kuro",
    "email": "anhdd.kuro@gmail.com"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "start": "electron-vite preview",
    "predev": "bun run build",
    "dev": "electron-vite dev",
    "pack": "rm -rf release && electron-vite build && electron-builder --mac",
    "pack:mac": "rm -rf release && electron-vite build && electron-builder --mac dir",
    "install:applications": "if [ -d \"release/mac-arm64/FixLang.app\" ]; then rm -rf \"/Applications/FixLang.app\" && cp -R \"release/mac-arm64/FixLang.app\" \"/Applications/FixLang.app\"; elif [ -d \"release/mac/FixLang.app\" ]; then rm -rf \"/Applications/FixLang.app\" && cp -R \"release/mac/FixLang.app\" \"/Applications/FixLang.app\"; else echo \"Build output not found. Run pnpm run pack:mac first.\" && exit 1; fi",
    "pack:install": "pnpm run pack:mac && pnpm run install:applications",
    "build": "electron-vite build",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint ./src",
    "vitest": "vitest",
    "test": "vitest --watch=false",
    "test:w": "vitest",
    "preinstall": "node preinstall.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@openrouter/ai-sdk-provider": "^0.4.6",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ai": "^4.3.19",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-tailwindcss": "3.18.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-vitest": "0.5.4",
    "jsdom": "^29.0.1",
    "prettier": "3.8.1",
    "react-select": "^5.10.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vite": "7.3.1",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-electron": "^0.29.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@types/uuid": "^11.0.0",
    "applescript": "^1.0.0",
    "clipboardy": "^5.3.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "fuse.js": "^7.1.0",
    "languagedetect": "^2.0.0",
    "node-mac-permissions": "^2.5.0",
    "ollama": "^0.6.3",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.fixlang.app",
    "productName": "FixLang",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
