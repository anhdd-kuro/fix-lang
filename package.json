{
  "name": "fix-lang",
  "version": "0.2.5",
  "description": "Local macOS menu-bar app: AI text correction and writing tools via OpenAI, OpenRouter, or Ollama",
  "author": {
    "name": "Anhdd Kuro",
    "email": "anhdd.kuro@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anhdd-kuro/fix-lang.git"
  },
  "main": "./out/main/index.cjs",
  "type": "module",
  "scripts": {
    "start": "electron-vite preview",
    "predev": "bun run build",
    "dev": "electron-vite dev",
    "pack": "rm -rf release && electron-vite build && electron-builder --mac",
    "pack:mac": "rm -rf release && electron-vite build && electron-builder --mac dir",
    "release:mac": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --publish never",
    "install:applications": "if [ -d \"release/mac-arm64/FixLang.app\" ]; then rm -rf \"/Applications/FixLang.app\" && cp -R \"release/mac-arm64/FixLang.app\" \"/Applications/FixLang.app\"; elif [ -d \"release/mac/FixLang.app\" ]; then rm -rf \"/Applications/FixLang.app\" && cp -R \"release/mac/FixLang.app\" \"/Applications/FixLang.app\"; else echo \"Build output not found. Run pnpm run pack:mac first.\" && exit 1; fi",
    "pack:install": "bun run pack:mac && bun run install:applications",
    "prebuild": "bun run themes:generate",
    "build": "electron-vite build",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint ./src",
    "vitest": "vitest",
    "test": "vitest --watch=false",
    "test:w": "vitest",
    "themes:download": "bun run themes:download:tm && bun run themes:download:terminal",
    "themes:generate": "bun run scripts/generate-theme-css.ts",
    "themes:sync": "bun run themes:download && bun run themes:generate",
    "themes:download:terminal": "bun run scripts/download-terminalcolors.ts",
    "themes:download:tm": "bun run scripts/download-themes.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@openrouter/ai-sdk-provider": "3.0.0",
    "@tailwindcss/vite": "4.3.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.64.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.23",
    "ai": "7.0.31",
    "autoprefixer": "10.5.4",
    "colord": "^2.9.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "react-select": "5.10.2",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vite-plugin-commonjs": "0.10.4",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "29.0.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@types/uuid": "11.0.0",
    "applescript": "1.0.0",
    "chart.js": "^4.5.1",
    "clipboardy": "5.3.1",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "electron-squirrel-startup": "1.0.1",
    "electron-store": "11.0.2",
    "fuse.js": "7.5.0",
    "languagedetect": "2.0.0",
    "node-mac-permissions": "2.5.0",
    "ollama": "0.6.3",
    "openai": "6.48.0",
    "react": "19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "uuid": "14.0.1"
  },
  "build": {
    "appId": "com.fixlang.app",
    "productName": "FixLang",
    "publish": null,
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "notarize": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "writeUpdateInfo": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  },
  "trustedDependencies": [
    "electron",
    "electron-winstaller",
    "esbuild",
    "node-mac-permissions",
    "unrs-resolver"
  ]
}
