{
  "name": "fix-lang",
  "version": "0.1.0",
  "description": "A local macOS app that uses OpenAI to fix grammar and improve writing style",
  "author": {
    "name": "Anhdd Kuro",
    "email": "anhdd.kuro@gmail.com"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "start": "electron-vite preview",
    "predev": "bun run build",
    "dev": "electron-vite dev",
    "pack": "rm -rf release && electron-vite build && electron-builder --mac",
    "build": "rm -rf release && electron-vite build",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint ./src"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "9.24.0",
    "eslint-config-prettier": "10.1.2",
    "eslint-import-resolver-typescript": "4.3.2",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-import-x": "4.10.5",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.2.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-tailwindcss": "3.18.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "eslint-plugin-vitest": "0.5.4",
    "prettier": "3.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "clipboardy": "^4.0.0",
    "dotenv": "^16.5.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^10.0.1",
    "languagedetect": "^2.0.0",
    "node-mac-permissions": "^2.5.0",
    "openai": "^4.94.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite-plugin-electron": "^0.29.0"
  },
  "build": {
    "appId": "com.fixlang.app",
    "productName": "FixLang",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}